# TeamFlow AI deployment environment example.
# Copy this file to .env before docker compose deployment and fill real values.

JWT_SECRET=change-me-to-a-random-64-byte-secret

TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=teamflow_ai

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DEMO_DAILY_LIMIT=100

# 2C2G 轻量本地 RAG
RAG_ENABLED=true
RAG_LOCAL_EMBEDDING=true
RAG_MIN_AVAILABLE_MEMORY_MB=250
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_COLLECTION=teamflow_ai_knowledge_chunks
QDRANT_MEM_LIMIT=384m
QDRANT_CPUS=0.75
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=1
EMBEDDING_MAX_TEXT_CHARS=4000
EMBEDDING_MEM_LIMIT=768m
EMBEDDING_CPUS=1.0
RAG_DENSE_TOP_K=20
RAG_KEYWORD_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_INDEX_WORKER_ENABLED=true
RAG_INDEX_WORKER_DELAY_MS=5000

# Umami 访问统计（openssl rand -hex 32 生成）
UMAMI_APP_SECRET=change-me-to-a-random-32-byte-secret

# 部署管理（系统管理 → 部署管理页面）
# 开启后超管可在页面一键触发 deploy.sh，实时查看日志
# 需同时在宿主机运行: sudo bash deploy-agent.sh --install
DEPLOY_ENABLED=false
