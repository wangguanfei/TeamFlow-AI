<?xml version="1.0" encoding="UTF-8"?>
<!--
  TeamFlow AI 日志配置

  目标：
  1. 让 TraceIdFilter 写入 MDC 的 traceId 真正打印出来，实现请求链路追踪；
  2. 控制台 + 文件双输出，应用日志与错误日志分离，便于线上排查；
  3. 文件按天 + 大小滚动，限制总量，避免磁盘被写爆。

  日志目录通过环境变量 LOG_DIR 覆盖，默认 ./logs（相对后端进程工作目录）。
-->
<configuration scan="true" scanPeriod="60 seconds">

    <!-- 日志输出目录：优先读取环境变量 LOG_DIR，未设置时落到 ./logs -->
    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <!-- 统一日志格式：时间 线程 级别 [traceId] 类名 - 消息。traceId 缺省显示为 "-" -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-}] %logger{40} - %msg%n"/>

    <!-- 控制台：本地开发 / docker stdout（被启动脚本重定向到 backend.log） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 应用主日志：INFO 及以上，按天滚动，单文件 50MB，保留 14 天，总量上限 2GB -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/teamflow-ai.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/teamflow-ai.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 错误日志：只收 WARN/ERROR，单独成文件，方便快速定位异常 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/teamflow-ai-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/teamflow-ai-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 业务包默认 INFO，可通过 application.yml 的 logging.level 覆盖 -->
    <logger name="com.teamflow.ai" level="INFO"/>
    <!-- MyBatis-Plus / SQL：开发排查时可临时调成 DEBUG 查看 SQL，默认收敛 -->
    <logger name="com.baomidou.mybatisplus" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>
</configuration>
