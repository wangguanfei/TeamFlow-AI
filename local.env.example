# TeamFlow AI 本机 Docker 验证环境。
# 复制为 .env.local 后按本机情况调整：
# cp local.env.example .env.local

TZ=Asia/Shanghai

# 本机已有 MySQL/Redis，不由 Docker 启动。
# 如果本机 MySQL/Redis 不是默认地址或端口，只改这里。
LOCAL_MYSQL_HOST=host.docker.internal
LOCAL_MYSQL_PORT=3306
LOCAL_MYSQL_DATABASE=teamflow_ai
LOCAL_MYSQL_USERNAME=root
LOCAL_MYSQL_PASSWORD=wgf123456

LOCAL_REDIS_HOST=host.docker.internal
LOCAL_REDIS_PORT=6379
LOCAL_REDIS_DATABASE=0

# 本机端口映射。
LOCAL_FRONTEND_PORT=5173
LOCAL_BACKEND_PORT=8080
LOCAL_MINIO_API_PORT=19000
LOCAL_MINIO_CONSOLE_PORT=19001
LOCAL_QDRANT_PORT=6333
LOCAL_EMBEDDING_PORT=18000

JWT_SECRET=teamflow-ai-local-development-secret-change-me-64bytes

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DEMO_DAILY_LIMIT=100

# 轻量本地 RAG。
RAG_ENABLED=true
RAG_LOCAL_EMBEDDING=true
RAG_MIN_AVAILABLE_MEMORY_MB=250
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_COLLECTION=teamflow_ai_knowledge_chunks
QDRANT_MEM_LIMIT=384m
QDRANT_CPUS=0.75
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=1
EMBEDDING_MAX_TEXT_CHARS=4000
EMBEDDING_MEM_LIMIT=768m
EMBEDDING_CPUS=1.0
RAG_DENSE_TOP_K=20
RAG_KEYWORD_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_INDEX_WORKER_ENABLED=true
RAG_INDEX_WORKER_DELAY_MS=5000

BACKEND_MEM_LIMIT=512m
BACKEND_CPUS=1.0

DEPLOY_ENABLED=false
